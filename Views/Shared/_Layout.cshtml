<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>
        @ViewData["Title"] - Vehicle Parts Management System
    </title>

    <!-- BOOTSTRAP -->

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet">

    <!-- CUSTOM STYLES -->

    <style>

            body {
                margin: 0;
                font-family: 'Segoe UI', sans-serif;
                background: #f5f7fb;
                color: #1e293b;
            }

            /* NAVBAR */

            .navbar {
                background: linear-gradient(90deg,#0f172a,#1e3a8a);
                padding: 18px 40px;
                box-shadow: 0 4px 15px rgba(0,0,0,0.12);
            }

            .navbar-brand {
                color: white !important;
                font-size: 28px;
                font-weight: 800;
                letter-spacing: 0.5px;
            }

            .nav-link {
                color: white !important;
                font-size: 18px;
                font-weight: 500;
                margin-left: 18px;
                transition: 0.3s ease;
            }

                .nav-link:hover {
                    color: #93c5fd !important;
                    transform: translateY(-1px);
                }

            .navbar-toggler {
                border: none;
            }

                .navbar-toggler:focus {
                    box-shadow: none;
                }

            /* MAIN CONTAINER */

            .container-custom {
                padding: 50px;
            }

            /* FOOTER */

            footer {
                font-size: 16px;
                color: #64748b;
                padding-bottom: 20px;
            }

            /* RESPONSIVE */

            @@media (max-width: 768px) {

                .container-custom {
                    padding: 25px;
                }

                .navbar {
                    padding: 15px 20px;
                }

                .navbar-brand {
                    font-size: 22px;
                }

                .nav-link {
                    margin-left: 0;
                    margin-top: 10px;
                }
            }

    </style>

</head>

<body>

    <!-- NAVBAR -->

    <header>

        <nav class="navbar navbar-expand-lg">

            <div class="container-fluid">

                <!-- BRAND -->

                <a class="navbar-brand"
                   asp-controller="Home"
                   asp-action="Index">

                    🚗 Vehicle Parts Management

                </a>

                <!-- TOGGLER -->

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#navbarNav">

                    <span class="navbar-toggler-icon bg-light rounded-2 p-2">
                    </span>

                </button>

                <!-- NAV LINKS -->

                <div class="collapse navbar-collapse"
                     id="navbarNav">

                    <ul class="navbar-nav ms-auto">

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="Home"
                               asp-action="Index">

                                Home

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="Parts"
                               asp-action="Index">

                                Parts

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link"
                               asp-controller="Suppliers"
                               asp-action="Index">

                                Suppliers

                            </a>

                        </li>

                        <li class="nav-item">

                            <a class="nav-link"
                               href="/swagger">

                                API

                            </a>

                        </li>

                    </ul>

                </div>

            </div>

        </nav>

    </header>

    <!-- MAIN CONTENT -->

    <div class="container-custom">

        <main role="main">

            @RenderBody()

        </main>

    </div>

    <!-- FOOTER -->

    <footer class="text-center mt-5">

        &copy; 2026 - Vehicle Parts Management System |
        ASP.NET Core MVC + Web API

    </footer>

    <!-- BOOTSTRAP JS -->

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js">
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>