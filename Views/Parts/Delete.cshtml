@model VehiclePartsManagementSystem.Models.Part

@{
    ViewData["Title"] = "Delete Part";
}

<div class="container py-5">

    <div class="card border-0 shadow-lg rounded-5 p-5 text-center">

        <h1 class="display-5 fw-bold text-danger mb-4">
            Delete Part
        </h1>

        <p class="fs-4 text-secondary mb-5">
            Are you sure you want to delete this part?
        </p>

        <div class="card border-0 bg-light rounded-4 p-4 mb-5">

            <!-- PART NAME -->

            <h3 class="fw-bold mb-4">
                @Model.PartName
            </h3>

            <!-- QUANTITY -->

            <p class="fs-5">
                <strong>Quantity:</strong>
                @Model.Quantity
            </p>

            <!-- PRICE -->

            <p class="fs-5 text-success fw-bold">
                <strong>Price:</strong>
                $@Model.Price
            </p>

            <!-- SUPPLIER -->

            <p class="fs-5">

                <strong>Supplier:</strong>

                @(Model.Supplier != null
                    ? Model.Supplier.SupplierName
                    : "No Supplier Assigned")

            </p>

        </div>

        <form asp-action="Delete">

            <input type="hidden" asp-for="Id" />

            <div class="d-flex justify-content-center gap-3">

                <button type="submit"
                        class="btn btn-danger btn-lg rounded-4 px-4">

                    Delete

                </button>

                <a asp-action="Index"
                   class="btn btn-outline-secondary btn-lg rounded-4 px-4">

                    Cancel

                </a>

            </div>

        </form>

    </div>

</div>