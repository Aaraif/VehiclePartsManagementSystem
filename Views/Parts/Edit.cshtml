@model VehiclePartsManagementSystem.Models.Part

@{
    ViewData["Title"] = "Edit Part";
}

<div class="container py-5">

    <div class="card border-0 shadow-lg rounded-5 p-5">

        <!-- HEADING -->

        <div class="mb-4">

            <h1 class="display-5 fw-bold text-dark">
                Edit Part
            </h1>

            <p class="text-secondary fs-5 mt-3">
                Update the vehicle part information and supplier details below.
            </p>

        </div>

        <hr class="mb-5" />

        <div class="row justify-content-center">

            <div class="col-lg-8">

                <form asp-action="Edit">

                    <!-- VALIDATION -->

                    <div asp-validation-summary="ModelOnly"
                         class="alert alert-danger rounded-4 mb-4">
                    </div>

                    <input type="hidden" asp-for="Id" />

                    <!-- PART NAME -->

                    <div class="mb-4">

                        <label asp-for="PartName"
                               class="form-label fw-semibold fs-5">

                            Part Name

                        </label>

                        <input asp-for="PartName"
                               class="form-control form-control-lg rounded-4 shadow-sm"
                               placeholder="Enter vehicle part name" />

                        <span asp-validation-for="PartName"
                              class="text-danger">
                        </span>

                    </div>

                    <!-- QUANTITY -->

                    <div class="mb-4">

                        <label asp-for="Quantity"
                               class="form-label fw-semibold fs-5">

                            Quantity

                        </label>

                        <input asp-for="Quantity"
                               class="form-control form-control-lg rounded-4 shadow-sm"
                               placeholder="Enter stock quantity" />

                        <span asp-validation-for="Quantity"
                              class="text-danger">
                        </span>

                    </div>

                    <!-- PRICE -->

                    <div class="mb-4">

                        <label asp-for="Price"
                               class="form-label fw-semibold fs-5">

                            Price

                        </label>

                        <input asp-for="Price"
                               class="form-control form-control-lg rounded-4 shadow-sm"
                               placeholder="Enter price" />

                        <span asp-validation-for="Price"
                              class="text-danger">
                        </span>

                    </div>

                    <!-- SUPPLIER -->

                    <div class="mb-4">

                        <label asp-for="SupplierId"
                               class="form-label fw-semibold fs-5">

                            Supplier

                        </label>

                        <select asp-for="SupplierId"
                                class="form-select form-select-lg rounded-4 shadow-sm"
                                asp-items="ViewBag.SupplierId">

                            <option value="">
                                -- Select Supplier --
                            </option>

                        </select>

                        <span asp-validation-for="SupplierId"
                              class="text-danger">
                        </span>

                    </div>

                    <!-- BUTTONS -->

                    <div class="d-flex gap-3 mt-5">

                        <button type="submit"
                                class="btn btn-primary btn-lg rounded-4 px-5 shadow-sm">

                            Save Changes

                        </button>

                        <a asp-action="Index"
                           class="btn btn-outline-secondary btn-lg rounded-4 px-5">

                            Back

                        </a>

                    </div>

                </form>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}