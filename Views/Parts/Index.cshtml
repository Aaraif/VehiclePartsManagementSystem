@model IEnumerable<VehiclePartsManagementSystem.Models.Part>

@{
    ViewData["Title"] = "Parts Inventory";

    var userRole =
        Context.Session.GetString("UserRole");

    var userId =
        Context.Session.GetInt32("UserId");
}

<div class="container py-5">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h1 class="display-4 fw-bold text-dark">
                Parts Inventory
            </h1>

            <p class="fs-5 text-secondary">
                Manage and purchase vehicle spare parts
            </p>

        </div>

        @if (userRole == "Admin" || userRole == "Staff")
        {
            <a asp-action="Create"
               class="btn btn-primary btn-lg px-4 py-3 rounded-4 shadow-sm">

                + Add Part

            </a>
        }

    </div>

    <!-- SUCCESS MESSAGE -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show rounded-4 shadow-sm mb-4"
             role="alert">

            @TempData["SuccessMessage"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert">
            </button>

        </div>
    }

    <!-- SEARCH -->

    <form asp-controller="Parts"
          asp-action="Index"
          method="get"
          class="mb-4">

        <div class="row g-2">

            <div class="col-md-4">

                <input type="text"
                       name="searchString"
                       class="form-control form-control-lg rounded-4"
                       placeholder="Search parts by name..." />

            </div>

            <div class="col-md-2">

                <button type="submit"
                        class="btn btn-dark btn-lg rounded-4 w-100">

                    Search

                </button>

            </div>

        </div>

    </form>

    <!-- PARTS TABLE -->

    <div class="card border-0 shadow-lg rounded-5 p-4 mt-4">

        <div class="table-responsive">

            <table class="table align-middle table-hover">

                <thead class="table-dark">

                    <tr class="fs-5">

                        <th>Part Name</th>

                        <th>Quantity</th>

                        <th>Price</th>

                        <th>Supplier</th>

                        <th class="text-center">
                            Actions
                        </th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr class="fs-5">

                            <td class="fw-semibold">
                                @item.PartName
                            </td>

                            <td>

                                @if (item.Quantity < 10)
                                {
                                    <span class="badge bg-danger fs-6">

                                        Low Stock :
                                        @item.Quantity

                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success fs-6">

                                        @item.Quantity Available

                                    </span>
                                }

                            </td>

                            <td class="fw-bold text-success">
                                $@item.Price
                            </td>

                            <td>
                                @(item.Supplier != null
                                    ? item.Supplier.SupplierName
                                    : "No Supplier")
                            </td>

                            <td>

                                <div class="d-flex justify-content-center gap-2 flex-wrap">

                                    <!-- DETAILS -->

                                    <a asp-action="Details"
                                       asp-route-id="@item.Id"
                                       class="btn btn-dark rounded-4 px-3">

                                        Details

                                    </a>

                                    <!-- BUY BUTTON -->
                                    @if (userId != null)
                                    {
                                        <a asp-controller="Sales"
                                           asp-action="Create"
                                           asp-route-partId="@item.Id"
                                           class="btn btn-success rounded-4 px-3">

                                            Buy

                                        </a>
                                    }

                                    <!-- STAFF / ADMIN ONLY -->
                                    @if (userRole == "Admin" ||
                                                                       userRole == "Staff")
                                    {
                                        <a asp-action="Edit"
                                           asp-route-id="@item.Id"
                                           class="btn btn-primary rounded-4 px-3">

                                            Edit

                                        </a>

                                        <a asp-action="Delete"
                                           asp-route-id="@item.Id"
                                           class="btn btn-danger rounded-4 px-3">

                                            Delete

                                        </a>
                                    }

                                </div>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>