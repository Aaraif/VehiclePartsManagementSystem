@model VehiclePartsManagementSystem.Models.Sale

@{
    ViewData["Title"] = "Delete Invoice";
}

<div class="container">

    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-body p-5">

            <h1 class="text-danger fw-bold mb-3">
                Delete Invoice
            </h1>

            <p class="fs-5 mb-4">
                Are you sure you want to delete this invoice?
            </p>

            <hr />

            <div class="row mt-4">

                <div class="col-md-6 mb-4">

                    <label class="fw-bold text-secondary">
                        Customer
                    </label>

                    <div class="fs-5">
                        @Model.Customer?.CustomerName
                    </div>

                </div>

                <div class="col-md-6 mb-4">

                    <label class="fw-bold text-secondary">
                        Vehicle Part
                    </label>

                    <div class="fs-5">
                        @Model.Part?.PartName
                    </div>

                </div>

                <div class="col-md-6 mb-4">

                    <label class="fw-bold text-secondary">
                        Quantity
                    </label>

                    <div class="fs-5">
                        @Model.Quantity
                    </div>

                </div>

                <div class="col-md-6 mb-4">

                    <label class="fw-bold text-secondary">
                        Total Amount
                    </label>

                    <div class="fs-5 text-danger fw-bold">
                        $@Model.TotalAmount
                    </div>

                </div>

                <div class="col-md-6 mb-4">

                    <label class="fw-bold text-secondary">
                        Sale Date
                    </label>

                    <div class="fs-5">
                        @Model.SaleDate.ToShortDateString()
                    </div>

                </div>

            </div>

            <form asp-action="Delete">

                <input type="hidden"
                       asp-for="Id" />

                <button type="submit"
                        class="btn btn-danger px-4 py-2 rounded-3">

                    Delete Invoice

                </button>

                <a asp-action="Index"
                   class="btn btn-secondary px-4 py-2 rounded-3 ms-2">

                    Back

                </a>

            </form>

        </div>

    </div>

</div>