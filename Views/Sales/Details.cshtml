@model VehiclePartsManagementSystem.Models.Sale

@{
    ViewData["Title"] = "Invoice Details";
}

<div class="container">

    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-body p-5">

            <div class="d-flex justify-content-between align-items-center mb-4">

                <h1 class="fw-bold text-success">
                    Invoice Details
                </h1>

                <span class="badge bg-success fs-6 px-3 py-2">
                    Completed
                </span>

            </div>

            <hr />

            <div class="row mt-4">

                <div class="col-md-6 mb-4">

                    <label class="fw-bold text-secondary">
                        Customer
                    </label>

                    <div class="fs-5">
                        @Model.Customer?.CustomerName
                    </div>

                </div>

                <div class="col-md-6 mb-4">

                    <label class="fw-bold text-secondary">
                        Vehicle Part
                    </label>

                    <div class="fs-5">
                        @Model.Part?.PartName
                    </div>

                </div>

                <div class="col-md-6 mb-4">

                    <label class="fw-bold text-secondary">
                        Quantity
                    </label>

                    <div class="fs-5">
                        @Model.Quantity
                    </div>

                </div>

                <div class="col-md-6 mb-4">

                    <label class="fw-bold text-secondary">
                        Total Amount
                    </label>

                    <div class="fs-5 text-success fw-bold">
                        $@Model.TotalAmount
                    </div>

                </div>

                <div class="col-md-6 mb-4">

                    <label class="fw-bold text-secondary">
                        Sale Date
                    </label>

                    <div class="fs-5">
                        @Model.SaleDate.ToShortDateString()
                    </div>

                </div>

            </div>

            <div class="mt-4">

                <a asp-action="Edit"
                   asp-route-id="@Model.Id"
                   class="btn btn-warning px-4 py-2 rounded-3">

                    Edit Invoice

                </a>

                <a asp-action="Index"
                   class="btn btn-secondary px-4 py-2 rounded-3 ms-2">

                    Back

                </a>

            </div>

        </div>

    </div>

</div>