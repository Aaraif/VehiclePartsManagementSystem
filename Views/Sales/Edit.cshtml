@model VehiclePartsManagementSystem.Models.Sale

@{
    ViewData["Title"] = "Edit Invoice";
}

<div class="container">

    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-body p-5">

            <h1 class="fw-bold text-warning mb-4">
                Edit Sales Invoice
            </h1>

            <p class="text-muted fs-5">
                Update customer invoice details
            </p>

            <hr />

            <form asp-action="Edit">

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3">
                </div>

                <input type="hidden"
                       asp-for="Id" />

                <div class="row">

                    <!-- CUSTOMER -->

                    <div class="col-md-6 mb-4">

                        <label asp-for="CustomerId"
                               class="form-label fw-bold">

                            Customer

                        </label>

                        <select asp-for="CustomerId"
                                class="form-select form-select-lg rounded-3"
                                asp-items="ViewBag.CustomerId">

                            <option value="">
                                Select Customer
                            </option>

                        </select>

                    </div>

                    <!-- PART -->

                    <div class="col-md-6 mb-4">

                        <label asp-for="PartId"
                               class="form-label fw-bold">

                            Vehicle Part

                        </label>

                        <select asp-for="PartId"
                                class="form-select form-select-lg rounded-3"
                                asp-items="ViewBag.PartId">

                            <option value="">
                                Select Part
                            </option>

                        </select>

                    </div>

                    <!-- QUANTITY -->

                    <div class="col-md-6 mb-4">

                        <label asp-for="Quantity"
                               class="form-label fw-bold">
                        </label>

                        <input asp-for="Quantity"
                               class="form-control form-control-lg rounded-3" />

                        <span asp-validation-for="Quantity"
                              class="text-danger">
                        </span>

                    </div>

                    <!-- TOTAL -->

                    <div class="col-md-6 mb-4">

                        <label asp-for="TotalAmount"
                               class="form-label fw-bold">

                            Total Amount

                        </label>

                        <input asp-for="TotalAmount"
                               class="form-control form-control-lg rounded-3" />

                        <span asp-validation-for="TotalAmount"
                              class="text-danger">
                        </span>

                    </div>

                </div>

                <div class="mt-4">

                    <button type="submit"
                            class="btn btn-warning btn-lg px-4 rounded-3">

                        Update Invoice

                    </button>

                    <a asp-action="Index"
                       class="btn btn-secondary btn-lg px-4 rounded-3 ms-2">

                        Back

                    </a>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}