@{
    ViewData["Title"] = "Home";
}

<div class="container py-5">

    <!-- HERO SECTION -->

    <div class="text-center mb-5">

        <h1 class="display-2 fw-bold text-dark">

            Vehicle Parts Management System

        </h1>

        <p class="lead text-secondary mt-4 fs-4">

            A modern ASP.NET Core MVC + Web API application
            for managing vehicle spare parts, suppliers,
            customers, sales invoices and inventory operations efficiently.

        </p>

    </div>

    <!-- MAIN MODULES -->

    <div class="row g-4">

        <!-- PARTS MODULE -->

        <div class="col-lg-4">

            <div class="card border-0 shadow-lg rounded-5 h-100">

                <div class="card-body text-center p-5">

                    <div style="font-size:75px;">
                        📦
                    </div>

                    <h2 class="fw-bold mt-4">

                        Parts Management

                    </h2>

                    <p class="text-muted mt-4 fs-5">

                        Manage vehicle spare parts,
                        stock quantity and pricing efficiently.

                    </p>

                    <a asp-controller="Parts"
                       asp-action="Index"
                       class="btn btn-primary btn-lg rounded-pill px-5 mt-4 shadow-sm">

                        Open Parts

                    </a>

                </div>

            </div>

        </div>

        <!-- SUPPLIERS MODULE -->

        <div class="col-lg-4">

            <div class="card border-0 shadow-lg rounded-5 h-100">

                <div class="card-body text-center p-5">

                    <div style="font-size:75px;">
                        🚚
                    </div>

                    <h2 class="fw-bold mt-4">

                        Suppliers

                    </h2>

                    <p class="text-muted mt-4 fs-5">

                        Store supplier records,
                        contacts and addresses professionally.

                    </p>

                    <a asp-controller="Suppliers"
                       asp-action="Index"
                       class="btn btn-dark btn-lg rounded-pill px-5 mt-4 shadow-sm">

                        Open Suppliers

                    </a>

                </div>

            </div>

        </div>

        <!-- SALES MODULE -->

        <div class="col-lg-4">

            <div class="card border-0 shadow-lg rounded-5 h-100">

                <div class="card-body text-center p-5">

                    <div style="font-size:75px;">
                        💰
                    </div>

                    <h2 class="fw-bold mt-4">

                        Sales & Invoices

                    </h2>

                    <p class="text-muted mt-4 fs-5">

                        Generate invoices,
                        manage customer sales and revenue tracking.

                    </p>

                    <a asp-controller="Sales"
                       asp-action="Index"
                       class="btn btn-success btn-lg rounded-pill px-5 mt-4 shadow-sm">

                        Open Sales

                    </a>

                </div>

            </div>

        </div>

    </div>

    <!-- DASHBOARD STATS -->

    <div class="mt-5">

        <div class="mb-4">

            <h2 class="fw-bold text-dark">

                Financial Dashboard & Reports

            </h2>

            <p class="text-secondary fs-5">

                Real-time analytics for sales, revenue and inventory management.

            </p>

        </div>

        <!-- FIRST ROW -->

        <div class="row g-4">

            <!-- TOTAL PARTS -->

            <div class="col-md-3">

                <div class="card border-0 shadow-sm rounded-5 text-center p-4 h-100">

                    <div style="font-size:60px;">
                        📦
                    </div>

                    <h1 class="fw-bold mt-3 text-primary">

                        @ViewBag.TotalParts

                    </h1>

                    <p class="text-muted fs-5">

                        Total Parts

                    </p>

                </div>

            </div>

            <!-- TOTAL SUPPLIERS -->

            <div class="col-md-3">

                <div class="card border-0 shadow-sm rounded-5 text-center p-4 h-100">

                    <div style="font-size:60px;">
                        🚚
                    </div>

                    <h1 class="fw-bold mt-3 text-dark">

                        @ViewBag.TotalSuppliers

                    </h1>

                    <p class="text-muted fs-5">

                        Total Suppliers

                    </p>

                </div>

            </div>

            <!-- TOTAL CUSTOMERS -->

            <div class="col-md-3">

                <div class="card border-0 shadow-sm rounded-5 text-center p-4 h-100">

                    <div style="font-size:60px;">
                        👥
                    </div>

                    <h1 class="fw-bold mt-3 text-info">

                        @ViewBag.TotalCustomers

                    </h1>

                    <p class="text-muted fs-5">

                        Total Customers

                    </p>

                </div>

            </div>

            <!-- TOTAL SALES -->

            <div class="col-md-3">

                <div class="card border-0 shadow-sm rounded-5 text-center p-4 h-100">

                    <div style="font-size:60px;">
                        🧾
                    </div>

                    <h1 class="fw-bold mt-3 text-success">

                        @ViewBag.TotalSales

                    </h1>

                    <p class="text-muted fs-5">

                        Total Sales

                    </p>

                </div>

            </div>

        </div>

        <!-- SECOND ROW -->

        <div class="row g-4 mt-1">

            <!-- TOTAL STOCK -->

            <div class="col-md-3">

                <div class="card border-0 shadow-sm rounded-5 text-center p-4 h-100">

                    <div style="font-size:60px;">
                        📊
                    </div>

                    <h1 class="fw-bold mt-3 text-success">

                        @ViewBag.TotalQuantity

                    </h1>

                    <p class="text-muted fs-5">

                        Total Stock

                    </p>

                </div>

            </div>

            <!-- TOTAL REVENUE -->

            <div class="col-md-3">

                <div class="card border-0 shadow-sm rounded-5 text-center p-4 h-100">

                    <div style="font-size:60px;">
                        💵
                    </div>

                    <h1 class="fw-bold mt-3 text-success">

                        $@ViewBag.TotalRevenue

                    </h1>

                    <p class="text-muted fs-5">

                        Total Revenue

                    </p>

                </div>

            </div>

            <!-- TODAY REVENUE -->

            <div class="col-md-3">

                <div class="card border-0 shadow-sm rounded-5 text-center p-4 h-100">

                    <div style="font-size:60px;">
                        📅
                    </div>

                    <h1 class="fw-bold mt-3 text-primary">

                        $@ViewBag.TodayRevenue

                    </h1>

                    <p class="text-muted fs-5">

                        Today Revenue

                    </p>

                </div>

            </div>

            <!-- MONTHLY REVENUE -->

            <div class="col-md-3">

                <div class="card border-0 shadow-sm rounded-5 text-center p-4 h-100">

                    <div style="font-size:60px;">
                        📈
                    </div>

                    <h1 class="fw-bold mt-3 text-warning">

                        $@ViewBag.MonthlyRevenue

                    </h1>

                    <p class="text-muted fs-5">

                        Monthly Revenue

                    </p>

                </div>

            </div>

        </div>

        <!-- THIRD ROW -->

        <div class="row g-4 mt-1">

            <!-- YEARLY REVENUE -->

            <div class="col-md-4">

                <div class="card border-0 shadow-sm rounded-5 text-center p-4 h-100">

                    <div style="font-size:60px;">
                        🏆
                    </div>

                    <h1 class="fw-bold mt-3 text-success">

                        $@ViewBag.YearlyRevenue

                    </h1>

                    <p class="text-muted fs-5">

                        Yearly Revenue

                    </p>

                </div>

            </div>

            <!-- TOP CUSTOMER -->

            <div class="col-md-4">

                <div class="card border-0 shadow-sm rounded-5 text-center p-4 h-100">

                    <div style="font-size:60px;">
                        👑
                    </div>

                    <h1 class="fw-bold mt-3 text-dark">

                        @ViewBag.TopCustomer

                    </h1>

                    <p class="text-muted fs-5">

                        Top Customer

                    </p>

                </div>

            </div>

            <!-- LOW STOCK -->

            <div class="col-md-4">

                <div class="card border-0 shadow-sm rounded-5 text-center p-4 h-100">

                    <div style="font-size:60px;">
                        ⚠️
                    </div>

                    <h1 class="fw-bold mt-3 text-danger">

                        @ViewBag.LowStockCount

                    </h1>

                    <p class="text-muted fs-5">

                        Low Stock Items

                    </p>

                </div>

            </div>

        </div>

    </div>

    <!-- TECHNOLOGIES -->

    <div class="mt-5">

        <div class="card border-0 shadow-sm rounded-5 p-5">

            <div class="text-center">

                <h2 class="fw-bold mb-4">

                    Technologies Used

                </h2>

                <div class="d-flex flex-wrap justify-content-center gap-3">

                    <span class="badge bg-dark fs-6 px-4 py-3 rounded-pill">
                        ASP.NET Core MVC
                    </span>

                    <span class="badge bg-primary fs-6 px-4 py-3 rounded-pill">
                        Web API
                    </span>

                    <span class="badge bg-success fs-6 px-4 py-3 rounded-pill">
                        SQL Server
                    </span>

                    <span class="badge bg-secondary fs-6 px-4 py-3 rounded-pill">
                        Entity Framework Core
                    </span>

                    <span class="badge bg-danger fs-6 px-4 py-3 rounded-pill">
                        Bootstrap 5
                    </span>

                </div>

            </div>

        </div>

    </div>

</div>