@model IEnumerable<VehiclePartsManagementSystem.Models.Customer>

@{
    ViewData["Title"] = "Customers";
}

<div class="container">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>

            <h1 class="fw-bold text-primary">
                Customers Management
            </h1>

            <p class="text-muted">
                Manage customer records and vehicle details
            </p>

        </div>

        <a asp-action="Create"
           class="btn btn-primary btn-lg rounded-3 shadow-sm">

            + Add Customer

        </a>

    </div>

    <!-- SEARCH BAR -->

    <div class="card border-0 shadow-sm rounded-4 mb-4">

        <div class="card-body">

            <form asp-action="Index"
                  method="get">

                <div class="row">

                    <div class="col-md-10">

                        <input type="text"
                               name="searchString"
                               class="form-control form-control-lg rounded-3"
                               placeholder="Search by customer name, phone or vehicle number..." />

                    </div>

                    <div class="col-md-2">

                        <button type="submit"
                                class="btn btn-dark btn-lg w-100 rounded-3">

                            Search

                        </button>

                    </div>

                </div>

            </form>

        </div>

    </div>

    <!-- TABLE -->

    <div class="card border-0 shadow-lg rounded-4">

        <div class="card-body p-4">

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-dark">

                        <tr>

                            <th>Customer Name</th>

                            <th>Phone</th>

                            <th>Vehicle Number</th>

                            <th>Address</th>

                            <th class="text-center">
                                Actions
                            </th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {
                            <tr>

                                <td class="fw-semibold">
                                    @item.CustomerName
                                </td>

                                <td>
                                    @item.Phone
                                </td>

                                <td>
                                    @item.VehicleNumber
                                </td>

                                <td>
                                    @item.Address
                                </td>

                                <td class="text-center">

                                    <a asp-action="Details"
                                       asp-route-id="@item.Id"
                                       class="btn btn-info btn-sm rounded-3 me-1">

                                        Details

                                    </a>

                                    <a asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       class="btn btn-warning btn-sm rounded-3 me-1">

                                        Edit

                                    </a>

                                    <a asp-action="Delete"
                                       asp-route-id="@item.Id"
                                       class="btn btn-danger btn-sm rounded-3">

                                        Delete

                                    </a>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>