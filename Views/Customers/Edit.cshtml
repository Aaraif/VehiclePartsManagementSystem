@model VehiclePartsManagementSystem.Models.Customer

@{
    ViewData["Title"] = "Edit Customer";

    var userRole =
        Context.Session.GetString("UserRole");
}

<div class="container">

    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-body p-5">

            <div class="d-flex justify-content-between align-items-center mb-4">

                <h1 class="fw-bold text-warning">
                    Edit Customer
                </h1>

                <span class="badge bg-dark fs-6 px-3 py-2">

                    Current Role:
                    @Model.Role

                </span>

            </div>

            <hr />

            <form asp-action="Edit">

                <div asp-validation-summary="ModelOnly"
                     class="text-danger mb-3">
                </div>

                <input type="hidden"
                       asp-for="Id" />

                <div class="row">

                    <!-- CUSTOMER NAME -->

                    <div class="col-md-6 mb-4">

                        <label asp-for="CustomerName"
                               class="form-label fw-bold">
                        </label>

                        <input asp-for="CustomerName"
                               class="form-control form-control-lg rounded-3" />

                        <span asp-validation-for="CustomerName"
                              class="text-danger">
                        </span>

                    </div>

                    <!-- EMAIL -->

                    <div class="col-md-6 mb-4">

                        <label asp-for="Email"
                               class="form-label fw-bold">
                        </label>

                        <input asp-for="Email"
                               class="form-control form-control-lg rounded-3" />

                        <span asp-validation-for="Email"
                              class="text-danger">
                        </span>

                    </div>

                    <!-- PASSWORD -->

                    <div class="col-md-6 mb-4">

                        <label asp-for="Password"
                               class="form-label fw-bold">
                        </label>

                        <input asp-for="Password"
                               class="form-control form-control-lg rounded-3" />

                        <span asp-validation-for="Password"
                              class="text-danger">
                        </span>

                    </div>

                    <!-- PHONE -->

                    <div class="col-md-6 mb-4">

                        <label asp-for="Phone"
                               class="form-label fw-bold">
                        </label>

                        <input asp-for="Phone"
                               class="form-control form-control-lg rounded-3" />

                        <span asp-validation-for="Phone"
                              class="text-danger">
                        </span>

                    </div>

                    <!-- VEHICLE NUMBER -->

                    <div class="col-md-6 mb-4">

                        <label asp-for="VehicleNumber"
                               class="form-label fw-bold">
                        </label>

                        <input asp-for="VehicleNumber"
                               class="form-control form-control-lg rounded-3" />

                        <span asp-validation-for="VehicleNumber"
                              class="text-danger">
                        </span>

                    </div>

                    <!-- ADDRESS -->

                    <div class="col-md-6 mb-4">

                        <label asp-for="Address"
                               class="form-label fw-bold">
                        </label>

                        <input asp-for="Address"
                               class="form-control form-control-lg rounded-3" />

                        <span asp-validation-for="Address"
                              class="text-danger">
                        </span>

                    </div>

                    <!-- ROLE -->
                    @if (userRole == "Admin")
                    {
                        <div class="col-md-6 mb-4">

                            <label asp-for="Role"
                                   class="form-label fw-bold">
                            </label>

                            <select asp-for="Role"
                                    class="form-select form-select-lg rounded-3">

                                <option value="Customer">
                                    Customer
                                </option>

                                <option value="Staff">
                                    Staff
                                </option>

                                <option value="Admin">
                                    Admin
                                </option>

                            </select>

                            <span asp-validation-for="Role"
                                  class="text-danger">
                            </span>

                        </div>
                    }
                    else
                    {
                        <input type="hidden"
                               asp-for="Role" />
                    }

                </div>

                <div class="mt-4">

                    <button type="submit"
                            class="btn btn-warning btn-lg px-4 rounded-3">

                        Update Customer

                    </button>

                    <a asp-action="Index"
                       class="btn btn-secondary btn-lg px-4 rounded-3 ms-2">

                        Back

                    </a>

                </div>

            </form>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}