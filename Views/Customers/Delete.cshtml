@model VehiclePartsManagementSystem.Models.Customer

@{
    ViewData["Title"] = "Delete Customer";
}

<div class="container">

    <div class="card shadow-lg border-0 rounded-4">

        <div class="card-body p-5">

            <h1 class="text-danger fw-bold mb-3">
                Delete Customer
            </h1>

            <p class="fs-5 mb-4">
                Are you sure you want to delete this customer?
            </p>

            <hr />

            <dl class="row mt-4">

                <dt class="col-sm-3 fw-bold">
                    Customer Name
                </dt>

                <dd class="col-sm-9">
                    @Model.CustomerName
                </dd>

                <dt class="col-sm-3 fw-bold">
                    Phone
                </dt>

                <dd class="col-sm-9">
                    @Model.Phone
                </dd>

                <dt class="col-sm-3 fw-bold">
                    Vehicle Number
                </dt>

                <dd class="col-sm-9">
                    @Model.VehicleNumber
                </dd>

                <dt class="col-sm-3 fw-bold">
                    Address
                </dt>

                <dd class="col-sm-9">
                    @Model.Address
                </dd>

            </dl>

            <form asp-action="Delete">

                <input type="hidden"
                       asp-for="Id" />

                <button type="submit"
                        class="btn btn-danger px-4 py-2 rounded-3">

                    Delete Customer

                </button>

                <a asp-action="Index"
                   class="btn btn-secondary px-4 py-2 rounded-3 ms-2">

                    Back

                </a>

            </form>

        </div>

    </div>

</div>