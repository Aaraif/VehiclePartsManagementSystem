@model VehiclePartsManagementSystem.Models.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<div class="container">

    <div class="row justify-content-center">

        <div class="col-md-6">

            <div class="card shadow-lg border-0 rounded-4 mt-5">

                <div class="card-body p-5">

                    <div class="text-center mb-4">

                        <h1 class="fw-bold text-primary">

                            System Login

                        </h1>

                        <p class="text-muted fs-5">

                            Login as Admin, Staff or Customer

                        </p>

                    </div>

                    <hr />

                    <form asp-action="Login">

                        <div asp-validation-summary="ModelOnly"
                             class="text-danger mb-3">
                        </div>

                        <!-- EMAIL -->

                        <div class="mb-4">

                            <label asp-for="Email"
                                   class="form-label fw-bold">
                            </label>

                            <input asp-for="Email"
                                   class="form-control form-control-lg rounded-3"
                                   placeholder="Enter your email" />

                            <span asp-validation-for="Email"
                                  class="text-danger">
                            </span>

                        </div>

                        <!-- PASSWORD -->

                        <div class="mb-4">

                            <label asp-for="Password"
                                   class="form-label fw-bold">
                            </label>

                            <input asp-for="Password"
                                   class="form-control form-control-lg rounded-3"
                                   placeholder="Enter your password" />

                            <span asp-validation-for="Password"
                                  class="text-danger">
                            </span>

                        </div>

                        <!-- BUTTONS -->

                        <div class="text-center mt-4">

                            <button type="submit"
                                    class="btn btn-primary btn-lg px-5 rounded-3">

                                Login

                            </button>

                            <a asp-controller="Customers"
                               asp-action="Create"
                               class="btn btn-success btn-lg px-5 rounded-3 ms-2">

                                Register

                            </a>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}