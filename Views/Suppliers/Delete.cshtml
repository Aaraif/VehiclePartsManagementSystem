@model VehiclePartsManagementSystem.Models.Supplier

@{
    ViewData["Title"] = "Delete Supplier";
}

<div class="container">

    <h1 class="text-danger">
        Delete Supplier
    </h1>

    <p style="margin-bottom:30px;">
        Are you sure you want to delete this supplier?
    </p>

    <div class="card">

        <div class="mb-4">

            <h5 class="text-secondary">
                Supplier Name
            </h5>

            <h3>
                @Model.SupplierName
            </h3>

        </div>

        <div class="mb-4">

            <h5 class="text-secondary">
                Contact Number
            </h5>

            <h3>
                @Model.ContactNumber
            </h3>

        </div>

        <div class="mb-4">

            <h5 class="text-secondary">
                Address
            </h5>

            <h3>
                @Model.Address
            </h3>

        </div>

        <form asp-action="Delete">

            <input type="hidden" asp-for="Id" />

            <button type="submit"
                    class="btn btn-danger">
                Delete
            </button>

            <a asp-action="Index"
               class="btn btn-secondary ms-2">
                Cancel
            </a>

        </form>

    </div>

</div>