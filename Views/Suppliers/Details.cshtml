@model VehiclePartsManagementSystem.Models.Supplier

@{
    ViewData["Title"] = "Supplier Details";
}

<div class="container">

    <h1>Supplier Details</h1>

    <p style="margin-bottom:30px;">
        View complete supplier information.
    </p>

    <div class="card">

        <div class="mb-4">

            <h5 class="text-secondary">
                Supplier Name
            </h5>

            <h3>
                @Model.SupplierName
            </h3>

        </div>

        <div class="mb-4">

            <h5 class="text-secondary">
                Contact Number
            </h5>

            <h3>
                @Model.ContactNumber
            </h3>

        </div>

        <div class="mb-4">

            <h5 class="text-secondary">
                Address
            </h5>

            <h3>
                @Model.Address
            </h3>

        </div>

        <a asp-action="Edit"
           asp-route-id="@Model.Id"
           class="btn btn-primary">
            Edit
        </a>

        <a asp-action="Index"
           class="btn btn-secondary ms-2">
            Back
        </a>

    </div>

</div>